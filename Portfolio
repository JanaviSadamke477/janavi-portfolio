<script>
// Cursor
const cur=document.getElementById('cursor'),ring=document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function anim(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(anim);})();
document.querySelectorAll('a,button,input,textarea').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='20px';cur.style.height='20px';ring.style.width='54px';ring.style.height='54px';});
  el.addEventListener('mouseleave',()=>{cur.style.width='12px';cur.style.height='12px';ring.style.width='36px';ring.style.height='36px';});
});

// Scroll progress + back-to-top
const pb=document.getElementById('progress'),bt=document.getElementById('back-top');
window.addEventListener('scroll',()=>{
  pb.style.width=(window.scrollY/(document.body.scrollHeight-window.innerHeight)*100)+'%';
  bt.classList.toggle('vis',window.scrollY>400);
});

// Reveal on scroll
const revEls=document.querySelectorAll('.reveal');
const ro=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*80);ro.unobserve(e.target);}});
},{threshold:.08});
revEls.forEach(el=>ro.observe(el));

// Typewriter
const phrases=['intelligent dashboards.','AI-powered tools.','data pipelines.','learning roadmaps.','end-to-end solutions.'];
let pi=0,ci=0,del=false;
const tw=document.getElementById('tw');
function type(){
  const p=phrases[pi];
  tw.textContent=del?p.substring(0,ci--):p.substring(0,ci++);
  if(!del&&ci>p.length){setTimeout(()=>del=true,1800);}
  else if(del&&ci<0){del=false;pi=(pi+1)%phrases.length;ci=0;}
  setTimeout(type,del?48:82);
}
type();

// Contact form submission → sends to Gmail via Formspree
document.getElementById('cForm').addEventListener('submit',async function(e){
  e.preventDefault();
  const btn=document.getElementById('subBtn'),txt=document.getElementById('btnTxt');
  btn.disabled=true; txt.textContent='Sending...';
  try{
    const r=await fetch(this.action,{method:'POST',body:new FormData(this),headers:{'Accept':'application/json'}});
    if(r.ok){
      document.getElementById('cForm').style.display='none';
      document.getElementById('fSuccess').style.display='block';
    } else {
      txt.textContent='Failed — email me directly!';
      btn.disabled=false;
    }
  } catch {
    txt.textContent='Error — email me directly!';
    btn.disabled=false;
  }
});
</script>
