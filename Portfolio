<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Janavi Sadmake — AI & Data Science Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Cabinet+Grotesk:wght@300;400;500;700;800&family=Sora:wght@300;400;600&display=swap" rel="stylesheet"/>
<style>
  :root{--bg:#060910;--surface:#0d1117;--surface2:#111827;--accent:#38bdf8;--accent2:#818cf8;--accent3:#34d399;--text:#f1f5f9;--muted:#64748b;--border:rgba(56,189,248,0.12);--glow:rgba(56,189,248,0.15);}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{background:var(--bg);color:var(--text);font-family:'Cabinet Grotesk',sans-serif;overflow-x:hidden;cursor:none;}
  .cursor{width:12px;height:12px;background:var(--accent);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .2s,height .2s;mix-blend-mode:screen;}
  .cursor-ring{width:36px;height:36px;border:1.5px solid rgba(56,189,248,0.5);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .2s,height .2s;}
  body::before{content:'';position:fixed;inset:0;z-index:1;opacity:.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");pointer-events:none;}
  #progress{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));z-index:200;width:0%;transition:width .1s;}
  nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:18px 60px;background:rgba(6,9,16,0.85);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);}
  .nav-logo{font-family:'Clash Display',sans-serif;font-size:22px;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
  .nav-links{display:flex;gap:32px;list-style:none;}
  .nav-links a{color:var(--muted);text-decoration:none;font-size:13px;font-weight:500;letter-spacing:.5px;text-transform:uppercase;transition:color .2s;position:relative;}
  .nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--accent);transition:width .25s;}
  .nav-links a:hover{color:var(--accent);}
  .nav-links a:hover::after{width:100%;}
  .nav-cta{padding:9px 22px;background:linear-gradient(135deg,var(--accent),#0284c7);border:none;border-radius:10px;color:#fff;font-size:13px;font-weight:700;font-family:'Cabinet Grotesk',sans-serif;cursor:none;text-decoration:none;transition:transform .2s,box-shadow .2s;}
  .nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(56,189,248,0.3);}
  section{position:relative;z-index:2;}
  /* HERO */
  #hero{min-height:100vh;display:flex;align-items:center;padding:120px 60px 80px;position:relative;overflow:hidden;}
  .hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(56,189,248,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(56,189,248,0.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black,transparent);}
  .orb{position:absolute;border-radius:50%;}
  .orb1{top:8%;right:4%;width:580px;height:580px;background:radial-gradient(circle,rgba(56,189,248,0.09),transparent 70%);animation:pulse 9s ease-in-out infinite;}
  .orb2{bottom:4%;left:-2%;width:420px;height:420px;background:radial-gradient(circle,rgba(129,140,248,0.07),transparent 70%);animation:pulse 13s ease-in-out infinite reverse;}
  .orb3{top:45%;right:22%;width:220px;height:220px;background:radial-gradient(circle,rgba(52,211,153,0.06),transparent 70%);animation:pulse 11s ease-in-out infinite 3s;}
  @keyframes pulse{0%,100%{transform:scale(1);opacity:.7}50%{transform:scale(1.2);opacity:1}}
  .hero-content{max-width:840px;position:relative;z-index:2;}
  .hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.22);border-radius:999px;padding:6px 18px;font-size:12px;color:var(--accent);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:28px;animation:fadeUp .6s ease both;}
  .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:blink 1.5s infinite;display:inline-block;}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
  .hero-name{font-family:'Clash Display',sans-serif;font-size:clamp(58px,9vw,108px);font-weight:700;line-height:.93;letter-spacing:-4px;animation:fadeUp .7s .1s ease both;}
  .hero-name .grad{background:linear-gradient(135deg,var(--accent) 0%,var(--accent2) 50%,var(--accent3) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-size:200%;animation:gradShift 4s ease infinite;}
  @keyframes gradShift{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}
  .hero-desc{margin-top:28px;font-size:18px;color:var(--muted);line-height:1.75;max-width:600px;font-family:'Sora',sans-serif;font-weight:300;animation:fadeUp .7s .2s ease both;}
  .typewriter{border-right:3px solid var(--accent);padding-right:4px;animation:cur .8s step-end infinite;}
  @keyframes cur{0%,100%{border-color:var(--accent)}50%{border-color:transparent}}
  .hero-cta{display:flex;gap:16px;margin-top:44px;animation:fadeUp .7s .3s ease both;flex-wrap:wrap;}
  .btn-primary{padding:15px 36px;background:linear-gradient(135deg,var(--accent),#0284c7);border:none;border-radius:14px;color:#fff;font-size:15px;font-weight:700;font-family:'Cabinet Grotesk',sans-serif;cursor:none;text-decoration:none;transition:transform .2s,box-shadow .2s;box-shadow:0 8px 32px rgba(56,189,248,0.25);}
  .btn-primary:hover{transform:translateY(-3px);box-shadow:0 20px 52px rgba(56,189,248,0.42);}
  .btn-outline{padding:15px 36px;background:transparent;border:1.5px solid var(--border);border-radius:14px;color:var(--text);font-size:15px;font-weight:600;font-family:'Cabinet Grotesk',sans-serif;cursor:none;text-decoration:none;transition:border-color .2s,background .2s;}
  .btn-outline:hover{border-color:var(--accent);background:rgba(56,189,248,0.05);}
  .hero-stats{display:flex;gap:56px;margin-top:64px;animation:fadeUp .7s .4s ease both;padding-top:44px;border-top:1px solid var(--border);flex-wrap:wrap;}
  .stat-num{font-family:'Clash Display',sans-serif;font-size:40px;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
  .stat-label{font-size:12px;color:var(--muted);margin-top:2px;text-transform:uppercase;letter-spacing:.5px;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
  /* ABOUT */
  #about{padding:100px 60px;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
  .about-card{background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:40px;position:relative;overflow:hidden;}
  .about-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
  .about-avatar{width:80px;height:80px;border-radius:20px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;font-family:'Clash Display',sans-serif;font-size:32px;font-weight:700;color:#fff;margin-bottom:20px;box-shadow:0 8px 32px rgba(56,189,248,0.3);}
  .about-card-name{font-family:'Clash Display',sans-serif;font-size:24px;font-weight:700;margin-bottom:4px;}
  .about-card-role{color:var(--accent);font-size:14px;font-weight:500;margin-bottom:20px;}
  .tag-cloud{display:flex;flex-wrap:wrap;gap:8px;}
  .tag{background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.15);border-radius:999px;padding:5px 14px;font-size:12px;color:var(--accent);font-weight:500;transition:transform .2s,background .2s;}
  .tag:hover{transform:scale(1.06);background:rgba(56,189,248,0.16);}
  .tag.p{background:rgba(129,140,248,0.08);border-color:rgba(129,140,248,0.15);color:var(--accent2);}
  .tag.g{background:rgba(52,211,153,0.08);border-color:rgba(52,211,153,0.15);color:var(--accent3);}
  .floating-badge{position:absolute;bottom:-16px;right:32px;background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:12px 20px;display:flex;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
  .section-label{font-size:11px;color:var(--accent);font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:10px;}
  .section-label::before{content:'';flex:0 0 24px;height:1px;background:var(--accent);}
  .section-title{font-family:'Clash Display',sans-serif;font-size:clamp(32px,4vw,52px);font-weight:700;line-height:1.05;letter-spacing:-2px;margin-bottom:20px;}
  .section-body{color:var(--muted);font-size:16px;line-height:1.8;font-family:'Sora',sans-serif;font-weight:300;}
  /* SKILLS */
  #skills{padding:100px 60px;}
  .skills-header{text-align:center;margin-bottom:60px;}
  .skills-header .section-label{justify-content:center;}
  .skills-header .section-label::before{display:none;}
  .skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;}
  .skill-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:32px;transition:all .3s;position:relative;overflow:hidden;}
  .skill-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at top left,var(--glow),transparent 60%);opacity:0;transition:opacity .3s;}
  .skill-card:hover{border-color:rgba(56,189,248,0.3);transform:translateY(-5px);box-shadow:0 20px 60px rgba(56,189,248,0.08);}
  .skill-card:hover::after{opacity:1;}
  .skill-icon{width:52px;height:52px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:18px;}
  .si-b{background:rgba(56,189,248,0.12);}
  .si-p{background:rgba(129,140,248,0.12);}
  .si-g{background:rgba(52,211,153,0.12);}
  .si-o{background:rgba(251,146,60,0.12);}
  .skill-name{font-size:17px;font-weight:700;margin-bottom:16px;}
  .skill-pills{display:flex;flex-wrap:wrap;gap:6px;}
  .pill{background:var(--surface2);border:1px solid rgba(255,255,255,0.06);border-radius:8px;padding:5px 12px;font-size:12px;color:rgba(241,245,249,0.7);font-weight:500;}
  /* PROJECTS */
  #projects{padding:100px 60px;}
  .projects-header{margin-bottom:56px;}
  .projects-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;}
  .project-card{background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:36px;transition:all .35s cubic-bezier(.22,1,.36,1);position:relative;overflow:hidden;display:flex;flex-direction:column;gap:16px;cursor:none;}
  .project-card.featured{grid-column:1/-1;display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center;background:linear-gradient(135deg,rgba(56,189,248,0.04),rgba(129,140,248,0.03));border-color:rgba(56,189,248,0.22);}
  .project-card.wide{grid-column:1/-1;}
  .project-card:hover{border-color:rgba(56,189,248,0.35);transform:translateY(-6px);box-shadow:0 32px 80px rgba(56,189,248,0.1);}
  .project-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(56,189,248,0.5),transparent);opacity:0;transition:opacity .3s;}
  .project-card:hover::before{opacity:1;}
  .project-number{font-family:'Clash Display',sans-serif;font-size:64px;font-weight:700;color:rgba(56,189,248,0.05);line-height:1;position:absolute;top:20px;right:24px;user-select:none;pointer-events:none;}
  .project-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.2);border-radius:999px;padding:4px 12px;font-size:11px;color:var(--accent);font-weight:700;letter-spacing:.5px;text-transform:uppercase;width:fit-content;}
  .project-badge.ai{background:rgba(129,140,248,0.08);border-color:rgba(129,140,248,0.2);color:var(--accent2);}
  .project-badge.iot{background:rgba(52,211,153,0.08);border-color:rgba(52,211,153,0.2);color:var(--accent3);}
  .project-title{font-family:'Clash Display',sans-serif;font-size:24px;font-weight:700;letter-spacing:-.5px;}
  .project-desc{color:var(--muted);font-size:15px;line-height:1.7;font-family:'Sora',sans-serif;font-weight:300;}
  .project-tech{display:flex;flex-wrap:wrap;gap:8px;}
  .tech-tag{background:var(--surface2);border:1px solid rgba(255,255,255,0.06);border-radius:8px;padding:5px 12px;font-size:12px;color:rgba(241,245,249,0.6);font-weight:500;}
  .project-features{display:flex;flex-direction:column;gap:10px;list-style:none;}
  .project-features li{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:var(--muted);line-height:1.6;font-family:'Sora',sans-serif;}
  .project-features li::before{content:'→';color:var(--accent);font-weight:700;flex-shrink:0;}
  .project-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:4px;}
  .demo-btn{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--accent),#0284c7);border:none;border-radius:10px;padding:11px 22px;color:#fff;font-size:13px;font-weight:700;font-family:'Cabinet Grotesk',sans-serif;cursor:none;text-decoration:none;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 20px rgba(56,189,248,0.25);width:fit-content;}
  .demo-btn:hover{transform:translateY(-2px);box-shadow:0 12px 36px rgba(56,189,248,0.4);}
  .demo-btn .ldot{width:7px;height:7px;border-radius:50%;background:#fff;animation:blink 1.5s infinite;display:inline-block;}
  .gh-btn{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:var(--text);box-shadow:none;}
  .gh-btn:hover{background:rgba(255,255,255,0.1);box-shadow:none;}
  /* EDUCATION */
  #education{padding:100px 60px;}
  .edu-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:20px;margin-top:48px;}
  .edu-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:32px;transition:all .3s;}
  .edu-card:hover{border-color:rgba(56,189,248,0.25);transform:translateY(-3px);}
  .edu-year{font-size:12px;color:var(--accent);font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;}
  .edu-degree{font-size:17px;font-weight:700;margin-bottom:6px;line-height:1.4;}
  .edu-school{color:var(--muted);font-size:14px;margin-bottom:16px;}
  .edu-score{display:inline-block;background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.2);border-radius:8px;padding:4px 12px;font-size:13px;color:var(--accent3);font-weight:700;}
  /* CERTS */
  #certifications{padding:80px 60px;}
  .cert-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-top:48px;}
  .cert-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px;transition:all .3s;display:flex;align-items:center;gap:16px;text-decoration:none;color:var(--text);cursor:none;position:relative;overflow:hidden;}
  .cert-card:hover{border-color:rgba(56,189,248,0.35);transform:translateY(-3px);box-shadow:0 16px 48px rgba(56,189,248,0.08);}
  .cert-card::after{content:'↗';position:absolute;top:14px;right:16px;font-size:14px;color:var(--accent);opacity:0;transition:opacity .2s,transform .2s;transform:translateX(-4px);}
  .cert-card:hover::after{opacity:1;transform:translateX(0);}
  .cert-logo{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
  .cert-name{font-size:14px;font-weight:700;margin-bottom:3px;}
  .cert-org{font-size:12px;color:var(--muted);}
  .cert-hint{font-size:11px;color:var(--accent);margin-top:4px;opacity:0;transition:opacity .2s;}
  .cert-card:hover .cert-hint{opacity:1;}
  /* ACHIEVEMENTS */
  #achievements{padding:80px 60px;}
  .ach-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-top:48px;}
  .ach-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:32px;transition:all .3s;display:flex;align-items:flex-start;gap:20px;}
  .ach-card:hover{border-color:rgba(56,189,248,0.25);transform:translateY(-3px);}
  .ach-icon{width:56px;height:56px;border-radius:18px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:26px;}
  .ai-gold{background:rgba(251,191,36,0.12);}
  .ai-silver{background:rgba(148,163,184,0.12);}
  .ach-title{font-size:17px;font-weight:700;margin-bottom:6px;}
  .ach-desc{font-size:14px;color:var(--muted);line-height:1.6;font-family:'Sora',sans-serif;}
  /* CONTACT */
  #contact{padding:100px 60px;}
  .contact-inner{max-width:960px;margin:0 auto;}
  .contact-header{text-align:center;margin-bottom:56px;}
  .contact-header .section-label{justify-content:center;}
  .contact-header .section-label::before{display:none;}
  .contact-grid{display:grid;grid-template-columns:1fr 1.5fr;gap:28px;align-items:start;}
  .info-card{background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:36px;position:relative;overflow:hidden;}
  .info-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);}
  .info-title{font-family:'Clash Display',sans-serif;font-size:22px;font-weight:700;margin-bottom:8px;}
  .info-sub{color:var(--muted);font-size:14px;margin-bottom:28px;font-family:'Sora',sans-serif;line-height:1.6;}
  .clink-list{display:flex;flex-direction:column;gap:12px;}
  .clink{display:flex;align-items:center;gap:12px;background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:14px 18px;text-decoration:none;color:var(--text);font-size:14px;font-weight:600;transition:all .2s;}
  .clink:hover{border-color:var(--accent);color:var(--accent);background:rgba(56,189,248,0.05);transform:translateX(4px);}
  .clink svg{width:18px;height:18px;flex-shrink:0;}
  .form-card{background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:36px;position:relative;overflow:hidden;}
  .form-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent2),transparent);}
  .form-title{font-family:'Clash Display',sans-serif;font-size:22px;font-weight:700;margin-bottom:6px;}
  .form-sub{color:var(--muted);font-size:13px;margin-bottom:24px;font-family:'Sora',sans-serif;}
  .form-group{margin-bottom:16px;}
  .form-group label{display:block;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;}
  .form-group input,.form-group textarea{width:100%;padding:13px 16px;background:var(--surface2);border:1.5px solid rgba(255,255,255,0.07);border-radius:12px;color:var(--text);font-size:14px;font-family:'Cabinet Grotesk',sans-serif;outline:none;transition:border-color .2s,box-shadow .2s;resize:none;}
  .form-group input::placeholder,.form-group textarea::placeholder{color:var(--muted);}
  .form-group input:focus,.form-group textarea:focus{border-color:rgba(56,189,248,0.4);box-shadow:0 0 0 3px rgba(56,189,248,0.08);}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  .btn-submit{width:100%;padding:15px;background:linear-gradient(135deg,var(--accent),#0284c7);border:none;border-radius:12px;color:#fff;font-size:15px;font-weight:700;font-family:'Cabinet Grotesk',sans-serif;cursor:none;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 24px rgba(56,189,248,0.25);display:flex;align-items:center;justify-content:center;gap:8px;}
  .btn-submit:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(56,189,248,0.4);}
  .btn-submit:disabled{opacity:.6;cursor:not-allowed;transform:none;}
  .form-success{display:none;text-align:center;padding:32px 16px;}
  .form-success .si{font-size:52px;margin-bottom:12px;}
  .form-success h3{font-family:'Clash Display',sans-serif;font-size:24px;margin-bottom:8px;}
  .form-success p{color:var(--muted);font-size:14px;}
  footer{padding:32px 60px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;color:var(--muted);font-size:13px;position:relative;z-index:2;}
